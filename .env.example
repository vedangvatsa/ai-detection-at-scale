# Example environment variables for ai-detection-at-scale.
# Copy to .env and fill in real values. .env is gitignored.

# Kaggle API credentials (for kernel push/monitor scripts)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# API configuration
# CORS_ORIGINS=https://your-frontend.com,https://app.your-frontend.com
# API_KEY=change-me-to-a-long-random-string
# CACHE_TTL_SECONDS=3600
# MAX_CACHE_ENTRIES=1000
